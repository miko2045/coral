{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "webapp",
  "compatibility_date": "2026-03-21",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "portal-kv-placeholder"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "portal-files"
    }
  ]
}
